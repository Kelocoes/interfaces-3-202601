{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "NestJS: Launch App",
            "skipFiles": [
                "<node_internals>/**"
            ],
            // Apunta al archivo principal compilado de NestJS
            "program": "${workspaceFolder}/dist/main.js",
            "preLaunchTask": "npx nest build",
            "outFiles": [
                "${workspaceFolder}/dist/**/*.js"
            ]
        }
    ]
}
